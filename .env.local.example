# Copy this file to .env.local and fill in the values.
# Never commit .env.local.

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Public URL of the running app. Used as the base for magic-link redirects.
# Local dev: http://localhost:3000
# Prod: your Vercel domain (e.g. https://turc-global-erp.vercel.app)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase project ref (only needed locally, to generate TypeScript types).
# Not read by the app at runtime — used by `npm run db:types`.
SUPABASE_PROJECT_REF=your-project-ref

# DEV ONLY — set to "true" to bypass the magic-link auth gate.
# When true:
#   - middleware skips the session check
#   - (app) layout renders a placeholder email in the sidebar
#   - mutations stamp `created_by`/`edited_by` as null
# Unset (or `false`) in production.
NEXT_PUBLIC_DISABLE_AUTH=false
